# AI Settings (OpenAI or local Ollama)
# For OpenAI:
# AI_API_URL=https://api.openai.com/v1/chat/completions
# AI_API_KEY=your_openai_api_key_here
# AI_MODEL=gpt-4o-mini

# For Ollama (Local):
AI_API_URL=http://localhost:11434/v1/chat/completions
AI_API_KEY=ollama
AI_MODEL=llama3

FPT_API_KEY=your_fpt_api_key_here
FPT_VOICE=banmai
FPT_SPEED=0
CRON_SCHEDULE="*/30 * * * *"
MAX_STORIES_PER_RUN=3


# Dual-Cron Configuration
ENABLE_SHORT_FORM=true
CRON_SCHEDULE_SHORT="*/30 * * * *"

ENABLE_LONG_FORM=false
CRON_SCHEDULE_LONG="*/45 * * * *"
MAX_LONG_FORM_STORIES_PER_RUN=1


SOURCES=reddit,vnexpress,dantri
SOURCE_FILTER=all

SHORT_FORM_ENABLED=true
SHORT_FORM_CRON=0 * * * *
SHORT_FORM_MAX_PER_RUN=1

MAX_STORIES_PER_SOURCE=3
QUEUE_MIN_BUFFER=3
QUEUE_MAX_BUFFER=10

VOZ_CRAWL_MODE=browser
VOZ_BROWSER_HEADLESS=false
VOZ_CHALLENGE_WAIT_MS=15000