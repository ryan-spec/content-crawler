# AI Settings (OpenAI or local Ollama)
# For OpenAI:
# AI_API_URL=https://api.openai.com/v1/chat/completions
# AI_API_KEY=your_openai_api_key_here
# AI_MODEL=gpt-4o-mini

# For Ollama (Local):
AI_API_URL=http://localhost:11434/v1/chat/completions
AI_API_KEY=ollama
AI_MODEL=llama3

FPT_API_KEY=your_fpt_api_key_here
FPT_VOICE=banmai
FPT_SPEED=0
CRON_SCHEDULE="*/30 * * * *"
MAX_STORIES_PER_RUN=3
